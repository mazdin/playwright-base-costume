{
    "name": "at-web-saucedemo",
    "version": "1.0.0",
    "description": "Playwright automation for SauceDemo with OOP/POM pattern",
    "scripts": {
        "test": "playwright test",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "test:cross": "cross-env CROSS_BROWSER=true playwright test",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "format": "prettier --write \"**/*.{ts,mjs,json,md}\"",
        "format:check": "prettier --check \"**/*.{ts,mjs,json,md}\"",
        "report": "playwright show-report",
        "allure:serve": "allure serve allure-results",
        "allure:generate": "allure generate allure-results --clean -o allure-report",
        "allure:open": "allure open allure-report",
        "test:allure": "playwright test && allure generate allure-results --clean -o allure-report && allure open allure-report",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,mjs}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{json,md}": "prettier --write"
    },
    "keywords": [
        "playwright",
        "automation",
        "testing",
        "typescript"
    ],
    "author": "",
    "license": "ISC",
    "engines": {
        "node": ">=20"
    },
    "devDependencies": {
        "@playwright/test": "^1.45.2",
        "@types/node": "^20.17.9",
        "allure-commandline": "^2.41.0",
        "allure-playwright": "^3.4.4",
        "cross-env": "^7.0.3",
        "eslint": "^10.4.1",
        "eslint-plugin-playwright": "^2.10.4",
        "husky": "^9.1.7",
        "lint-staged": "^15.2.10",
        "prettier": "^3.4.2",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0"
    },
    "dependencies": {
        "dotenv": "^16.4.5"
    }
}
