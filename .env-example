# ============================================================
# APPLICATION SETTINGS
# ============================================================
BASE_URL=https://your-app-url.com

# Primary test user credentials
USEREMAIL=user@example.com
PASSWORD=yourpassword

# Secondary test user credentials (optional)
USEREMAIL2=user2@example.com
PASSWORD2=yourpassword2

# Browser session caching (optional)
STORAGE_STATE=

# ============================================================
# DATABASE SETTINGS (MySQL)
# ============================================================
DB_HOST=localhost
DB_USER=root
DB_PASS=yourdbpassword
DB_NAME=your_database_name

# ============================================================
# APP-SPECIFIC SETTINGS (sesuaikan dengan kebutuhan)
# ============================================================
APP_COMPANY=
APP_BRANCH=

# ============================================================
# CI/CD SETTINGS
# ============================================================
# PLAYWRIGHT_HEADLESS=true
# CI=true
